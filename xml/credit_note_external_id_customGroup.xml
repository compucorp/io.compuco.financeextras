<?xml version="1.0" encoding="iso-8859-1" ?>
<!--
  Custom group used by the CreditNoteImporter API to remember which
  internal credit note belongs to a given CSV `credit_note_external_id`.

  IMPORTANT: this file is deliberately NOT named `*_install.xml`.

  CRM_Extension_Upgrader_Base::onInstall() globs `xml/*_install.xml`
  and auto-loads every match BEFORE postInstall() runs. Our setup
  manager (CreditNoteCustomGroupExtensionManager) registers the
  CreditNote entity in `cg_extend_objects` from postInstall(), so a
  file matching the `*_install.xml` pattern would be loaded first and
  CRM_Core_BAO_CustomGroup::mapTableName('CreditNote') would fail
  with "Unknown extends" because the entity isn't registered yet.

  Loading happens explicitly from CRM_Financeextras_Upgrader::postInstall
  (and upgrade_1007) AFTER the cg_extend_objects entry is in place.
-->
<CustomData>
  <CustomGroups>
    <CustomGroup>
      <name>credit_note_external_id</name>
      <title>Credit Note External ID</title>
      <extends>CreditNote</extends>
      <style>Inline</style>
      <collapse_display>0</collapse_display>
      <is_active>1</is_active>
      <table_name>civicrm_value_credit_note_ext_id</table_name>
      <is_multiple>0</is_multiple>
      <collapse_adv_display>0</collapse_adv_display>
      <is_reserved>1</is_reserved>
    </CustomGroup>
  </CustomGroups>
  <CustomFields>
    <CustomField>
      <name>external_id</name>
      <label>External ID</label>
      <data_type>String</data_type>
      <html_type>Text</html_type>
      <is_required>0</is_required>
      <is_searchable>1</is_searchable>
      <is_search_range>0</is_search_range>
      <is_active>1</is_active>
      <is_view>1</is_view>
      <text_length>255</text_length>
      <note_columns>60</note_columns>
      <note_rows>4</note_rows>
      <column_name>external_id</column_name>
      <custom_group_name>credit_note_external_id</custom_group_name>
    </CustomField>
  </CustomFields>
</CustomData>
